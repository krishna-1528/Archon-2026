rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - only the authenticated user can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow create only for new users; block paidStatus and passType from client
      allow create: if request.auth != null
        && request.auth.uid == userId
        && !('paidStatus' in request.resource.data)
        == false  // paidStatus must be false on create
        && request.resource.data.paidStatus == false
        && request.resource.data.passType == 'General';

      // Allow update but NEVER let client change paidStatus or passType
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !('paidStatus' in request.resource.data.diff(resource.data).affectedKeys())
        && !('passType' in request.resource.data.diff(resource.data).affectedKeys());

      // No deletes from client side
      allow delete: if false;
    }

    // Block all other collections from client access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
